{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"description": "Custom renovate rules for @x2od",
	"extends": [
		":ignoreModulesAndTests",
		"group:react",
		"replacements:all",
		"workarounds:all",
		"docker:pinDigests",
		//":semanticCommitScope({{depName}})",
		":approveMajorUpdates",
		":separateMultipleMajorReleases",
		":widenPeerDependencies"
	],
	"schedule": [],
	"timezone": "America/Los_Angeles",
	"configMigration": true,
	"automergeType": "pr",
	"commitMessageLowerCase": "auto",
	"rangeStrategy": "bump",
	"commitBodyTable": true,
	"semanticCommits": "enabled",
	"semanticCommitScope": "{{depName}}",
	"commitMessageExtra": "from {{currentVersion}} to {{#if isPinDigest}}{{{newDigestShort}}}{{else}}{{#if isMajor}}{{newVersion}}{{else}}{{#if isSingleVersion}}{{newVersion}}{{else}}{{#if newValue}}{{{newVersion}}}{{else}}{{{newDigestShort}}}{{/if}}{{/if}}{{/if}}{{/if}}",
	"dependencyDashboard": true,
	"dependencyDashboardAutoclose": true,
	"configWarningReuseIssue": false,
	"separateMinorPatch": false,
	"pinDigests": false,
	"github-actions": {
		"description": "All Github updates",
		"automergeType": "pr",
		"managerFilePatterns": ["^(workflow-templates|\\.(?:github|gitea|forgejo)/workflows)/[^/]+\\.ya?ml$", "(^|/)action\\.ya?ml$"],
		"semanticCommitType": "ci",
		"semanticCommitScope": "{{depName}}",
		"commitMessageExtra": "from {{currentVersion}} to {{#if isPinDigest}}{{{newDigestShort}}}{{else}}{{#if isMajor}}{{prettyNewMajor}}{{else}}{{#if isSingleVersion}}{{prettyNewVersion}}{{else}}{{#if newValue}}{{{prettyNewVersion}}}{{else}}{{{newDigestShort}}}{{/if}}{{/if}}{{/if}}{{/if}}"
	},
	"major": { "autoApprove": true, "automerge": false, "addLabels": ["renovate", "major"] },
	"patch": { "autoApprove": true, "automerge": false, "addLabels": ["renovate", "patch"] },
	"minor": { "autoApprove": true, "automerge": false, "addLabels": ["renovate", "minor"] },
	"pre-commit": { "enabled": true },
	"vulnerabilityAlerts": { "enabled": true },
	"lockFileMaintenance": { "enabled": false },
	"packageRules": [
		{
			"description": "all minor/patch updates",
			"matchCurrentVersion": ">= 1.0.0",
			"matchUpdateTypes": ["minor", "patch"]
		},
		{
			"description": "npm dependencies (rare)",
			"semanticCommitType": "chore",
			"semanticCommitScope": "{{depName}}",
			"matchManagers": ["npm"],
			"matchDepTypes": ["dependencies"]
		},
		{
			"description": "npm devDependencies",
			"semanticCommitType": "build",
			"semanticCommitScope": "{{depName}}",
			"matchManagers": ["npm"],
			"matchDepTypes": ["devDependencies", "optionalDependencies"]
		},
		{
			"description": "npm peerDependencies",
			"matchManagers": ["npm"],
			"matchDepTypes": ["peerDependencies"],
			"rangeStrategy": "widen"
		},
		{
			"description": "renovate updates require approval",
			"matchManagers": ["npm"],
			"matchPackageNames": ["renovate"],
			"dependencyDashboardApproval": true
		},
		{
			"matchPackageNames": ["/jest/"],
			"groupName": "jest",
			"matchManagers": ["npm"],
			"semanticCommitType": "build",
			"semanticCommitScope": "jest packages"
		},
		{
			"matchPackageNames": ["/eslint/", "!eslint", "globals"],
			"groupName": "eslint plugins",
			"matchManagers": ["npm"],
			"semanticCommitType": "build",
			"semanticCommitScope": "eslint plugins"
		},
		{
			"description": "Github minor/patch updates",
			"matchCurrentVersion": ">= 1.0.0",
			"matchManagers": ["github-actions"],
			"matchUpdateTypes": ["minor", "patch"],
			"enabled": false
		},
		{
			"description": "Github major updates",
			"matchCurrentVersion": ">= 1.0.0",
			"matchManagers": ["github-actions"],
			"matchUpdateTypes": ["major"],
			"automerge": false,
			"autoApprove": true,
			"dependencyDashboardApproval": true
		},
		{
			"description": "All GitHub updates",
			"matchManagers": ["github-actions"]
		},
		{
			"description": "All prerelease",
			"matchCurrentVersion": "< 1.0.0",
			"automerge": false,
			"autoApprove": false
		},
		{
			"matchManagers": ["npm"],
			"description": "All npm updates. Note commit extra message was set globally."
		},
		{
			"description": "Minor updates to automerge, to save time but allow some clutter, overriding all above rules",
			"matchManagers": ["npm"],
			"matchPackageNames": ["/prettier/", "lint-staged", "marked", "mocha", "husky", "release-please", "/@x2od/"],
			"matchUpdateTypes": ["minor"],
			"automerge": true,
			"autoApprove": true
		}
	]
}
